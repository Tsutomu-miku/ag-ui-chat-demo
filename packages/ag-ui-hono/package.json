{
  "name": "ag-ui-hono",
  "version": "0.1.0",
  "description": "AG-UI protocol HTTP endpoint adapter for Hono — aligned with Python add_langgraph_fastapi_endpoint",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run typecheck && pnpm run test:coverage && pnpm run build",
    "publish:check-name": "npm view ag-ui-hono version --registry=https://registry.npmjs.org",
    "publish:dry": "pnpm run build && npm pack --dry-run --cache ../../node_modules/.cache/npm/ag-ui-hono",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ag-ui/core": "^0.0.52",
    "@ag-ui/encoder": "^0.0.52",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "hono": ">=4.0.0"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "license": "MIT",
  "homepage": "https://github.com/Tsutomu-miku/ag-ui-chat-demo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tsutomu-miku/ag-ui-chat-demo.git",
    "directory": "packages/ag-ui-hono"
  },
  "bugs": {
    "url": "https://github.com/Tsutomu-miku/ag-ui-chat-demo/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
