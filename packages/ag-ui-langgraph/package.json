{
  "name": "ag-ui-langgraph",
  "version": "0.1.0",
  "description": "AG-UI protocol adapter for LangGraph \u2014 TypeScript implementation aligned with Python ag-ui-langgraph",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build",
    "publish:check-name": "npm view ag-ui-langgraph version --registry=https://registry.npmjs.org",
    "publish:dry": "pnpm run build && npm pack --dry-run --cache ../../node_modules/.cache/npm/ag-ui-langgraph",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ag-ui/core": "^0.0.52",
    "@langchain/core": "^0.3.80",
    "@langchain/langgraph": "^0.2.60",
    "@langchain/langgraph-supervisor": "^0.0.19",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vitest": "^3.2.4",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "@langchain/langgraph": ">=0.2.0",
    "@langchain/langgraph-supervisor": ">=0.0.19"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
