{
  "name": "ag-ui-langgraph",
  "version": "0.3.0",
  "description": "AG-UI protocol adapter for LangGraph \u2014 TypeScript implementation aligned with Python ag-ui-langgraph",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run typecheck && pnpm run test:coverage && pnpm run build",
    "publish:check-name": "npm view ag-ui-langgraph version --registry=https://registry.npmjs.org",
    "publish:dry": "pnpm run build && npm pack --dry-run --cache ../../node_modules/.cache/npm/ag-ui-langgraph",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ag-ui/core": "^0.0.52",
    "@langchain/core": "^0.3.80",
    "@langchain/langgraph": "^0.2.60",
    "@langchain/langgraph-supervisor": "^0.0.19",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "@langchain/langgraph": ">=0.2.0",
    "@langchain/langgraph-supervisor": ">=0.0.19"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "homepage": "https://github.com/Tsutomu-miku/ag-ui-chat-demo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tsutomu-miku/ag-ui-chat-demo.git",
    "directory": "packages/ag-ui-langgraph"
  },
  "bugs": {
    "url": "https://github.com/Tsutomu-miku/ag-ui-chat-demo/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
