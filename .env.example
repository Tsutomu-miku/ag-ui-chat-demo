# openai | openrouter
LLM_PROVIDER=openai

# debug | info | warn | error
LOG_LEVEL=info
# pretty | json
LOG_FORMAT=pretty

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

